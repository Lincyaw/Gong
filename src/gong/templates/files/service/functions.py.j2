async def calculate_order_total(price: float, quantity: int, discount_level: str = "none") -> float:
    """Calculate order total with discount."""
    total = price * quantity
    
    discounts = {
        "bronze": 0.05,
        "silver": 0.10,
        "gold": 0.15,
        "platinum": 0.20
    }
    
    discount = discounts.get(discount_level, 0.0)
    return total * (1 - discount)


