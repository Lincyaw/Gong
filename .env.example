# Environment Configuration Example
# Copy this file to .env and modify as needed

# Environment
ENVIRONMENT=development
DEBUG=true

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Kubernetes
USE_KUBERNETES=false
K8S_NAMESPACE_PREFIX=sim

# Database (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/platform

# Redis (optional)
# REDIS_URL=redis://localhost:6379/0

# Observability
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
PROMETHEUS_ENDPOINT=http://prometheus:9090
LOKI_ENDPOINT=http://loki:3100

# LLM Configuration (optional)
# OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-3.5-turbo

# Traffic Generation
DEFAULT_TRAFFIC_DURATION=5m
MAX_TRAFFIC_JOBS=10

# Chaos Engineering
MAX_CHAOS_EXPERIMENTS=5
CHAOS_SAFETY_MODE=true

# Resource Limits
MAX_SERVICES_PER_SIMULATION=50
MAX_CONCURRENT_SIMULATIONS=10
SIMULATION_TIMEOUT_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json